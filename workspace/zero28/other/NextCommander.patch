diff --git a/src/screen.h b/src/screen.h
index 5249165..0f45e9d 100644
--- a/src/screen.h
+++ b/src/screen.h
@@ -32,22 +32,36 @@ struct Screen
     SDL_Window *window;
 #endif
 
+    bool m_drain_pending = false;
+
     void flip() {
 #ifdef USE_SDL2
-		if (SDL_UpdateWindowSurface(window) <= -1) {
-			SDL_Log("%s", SDL_GetError());
-		}
-		surface = SDL_GetWindowSurface(window);
+        if (SDL_UpdateWindowSurface(window) <= -1) {
+            SDL_Log("%s", SDL_GetError());
+        }
+        surface = SDL_GetWindowSurface(window);
+#ifdef ZERO28
+        m_drain_pending = true;
+#endif
 #else
 #ifdef MIYOOMINI
-	GFX_Flip(surface);
+        GFX_Flip(surface);
 #else
-      SDL_Flip(surface);
-      surface = SDL_GetVideoSurface();
+        SDL_Flip(surface);
+        surface = SDL_GetVideoSurface();
 #endif
 #endif
     }
 
+#if defined(USE_SDL2) && defined(ZERO28)
+    void drainIdle() {
+        if (m_drain_pending) {
+            SDL_UpdateWindowSurface(window);
+            m_drain_pending = false;
+        }
+    }
+#endif
+
     // Called once at startup.
     int init();
 
diff --git a/src/window.cpp b/src/window.cpp
index e3e646e..5d099fa 100644
--- a/src/window.cpp
+++ b/src/window.cpp
@@ -108,7 +108,19 @@ int CWindow::execute()
                     //printf("joy:%d\n",event.jbutton.button); fflush(stdout);
                     SDL_utils::setMouseCursorEnabled(false);
                     SDL_Event key_event;
+#ifdef ZERO28
+                    // D-pad fires as buttons, not hats, on zero28 (JOY_UP=13,LEFT=14,RIGHT=15,DOWN=16)
+                    switch (event.jbutton.button) {
+                        case 13: key_event.key.keysym.sym = CMDR_KEY_UP;     break;
+                        case 16: key_event.key.keysym.sym = CMDR_KEY_DOWN;   break;
+                        case 14: key_event.key.keysym.sym = CMDR_KEY_LEFT;   break;
+                        case 15: key_event.key.keysym.sym = CMDR_KEY_RIGHT;  break;
+                        case 19: key_event.key.keysym.sym = CMDR_KEY_SYSTEM; break; // MENU
+                        default: key_event.key.keysym.sym = event.jbutton.button; break;
+                    }
+#else
                     key_event.key.keysym.sym = event.jbutton.button == CMDR_KEY_MENU ? CMDR_KEY_SYSTEM : event.jbutton.button;
+#endif
                     l_render = this->keyPress(key_event) || l_render;
                     if (m_retVal) l_loop = false;
                     break;
@@ -130,6 +142,26 @@ int CWindow::execute()
                     }
                     break;
                 }
+#ifdef ZERO28
+                case SDL_JOYAXISMOTION: {
+                    SDL_utils::setMouseCursorEnabled(false);
+                    const Sint16 threshold = 16384;
+                    SDL_Event axis_event;
+                    axis_event.key.keysym.sym = 0;
+                    if (event.jaxis.axis == 1) {        // AXIS_LY: up/down
+                        if (event.jaxis.value < -threshold)      axis_event.key.keysym.sym = CMDR_KEY_UP;
+                        else if (event.jaxis.value > threshold)  axis_event.key.keysym.sym = CMDR_KEY_DOWN;
+                    } else if (event.jaxis.axis == 0) { // AXIS_LX: left/right
+                        if (event.jaxis.value < -threshold)      axis_event.key.keysym.sym = CMDR_KEY_LEFT;
+                        else if (event.jaxis.value > threshold)  axis_event.key.keysym.sym = CMDR_KEY_RIGHT;
+                    }
+                    if (axis_event.key.keysym.sym) {
+                        l_render = this->keyPress(axis_event) || l_render;
+                        if (m_retVal) l_loop = false;
+                    }
+                    break;
+                }
+#endif
                 case SDL_QUIT: return m_retVal;
 #ifdef USE_SDL2
                 case SDL_TEXTINPUT:
@@ -175,6 +207,9 @@ int CWindow::execute()
             screen.flip();
             l_render = false;
         }
+#ifdef ZERO28
+        else { screen.drainIdle(); }
+#endif
         LimitFrameRate();
     }
 
